# Prisma database connection
# For local development, this uses a SQLite file in the prisma directory
DATABASE_URL="file:./dev.db"

# Snowflake connection (required for AI analysis of submissions)
# See: https://docs.snowflake.com/en/developer-guide/node-js/nodejs-driver
SNOWFLAKE_ACCOUNT=""          # e.g. "xy12345.us-east-1"
SNOWFLAKE_USER=""             # Your Snowflake username
SNOWFLAKE_PRIVATE_KEY_PATH="" # Path to your RSA private key file (e.g. "./keys/rsa_key.p8")
SNOWFLAKE_WAREHOUSE=""        # e.g. "COMPUTE_WH"
SNOWFLAKE_DATABASE=""         # e.g. "MY_DATABASE"
SNOWFLAKE_ROLE=""             # e.g. "MY_ROLE"
